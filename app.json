{
  "expo": {
    "name": "KinPics",
    "slug": "kinpics-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "plugins": [
      "expo-camera"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.kinpicsapp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#111827"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.anonymous.kinpicsapp"
    }
  }
}
